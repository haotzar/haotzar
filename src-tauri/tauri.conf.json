{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "haotzar",
  "version": "1.0.0",
  "identifier": "com.haotzer.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' asset: tauri: https: http://localhost:*; script-src 'self' 'unsafe-inline' 'unsafe-eval' asset: tauri: https: http://localhost:*; worker-src 'self' blob: asset: tauri: https:; style-src 'self' 'unsafe-inline' asset: tauri: https:; img-src 'self' data: https: asset: tauri: blob:; font-src 'self' data: asset: tauri: https:; connect-src 'self' http://localhost:* https://localhost:* asset: tauri: https: ws://localhost:*; media-src 'self' data: asset: tauri: https:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$RESOURCE/**"]
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "האוצר",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../resources/meilisearch/*": "./"
    },
    "copyright": "",
    "category": "Education",
    "shortDescription": "אפליקציה דסקטופ להצגת ספרים תורניים",
    "longDescription": "האוצר - אפליקציה דסקטופ מתקדמת להצגת וחיפוש בספרים תורניים",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": ""
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "he-IL"
      }
    }
  }
}
